# Africonnect Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key_here_change_this_to_something_secure

# Email Configuration (for password reset, notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# Frontend URL (for CORS)
FRONTEND_URL=https://africanconnect.net

# Default admin seeding (created once on first server start)
DEFAULT_ADMIN_EMAIL=char.wilsons@gmail.com
DEFAULT_ADMIN_PASSWORD=CHANGE_ME
DEFAULT_ADMIN_PSEUDO=African

# Admin Configuration (optional)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# File Upload Configuration
MAX_FILE_SIZE=5242880 # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf